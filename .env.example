# AiCrime - Environment Configuration
# Copy to .env locally (never commit .env)

# Server
PORT=3000
NODE_ENV=development

# Database (optional for local - SQLite works without config)
# For production (Render), set DATABASE_URL to your PostgreSQL connection string:
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Auth (future JWT support)
# JWT_SECRET=change_this_in_production
